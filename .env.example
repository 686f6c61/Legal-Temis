# Proveedores de IA: configura al menos uno. El sistema solo activa los que tengan clave.
LEGISLACION_ANTHROPIC_API_KEY=
LEGISLACION_OPENAI_API_KEY=
LEGISLACION_OPENROUTER_API_KEY=
LEGISLACION_NAN_API_KEY=

# Proveedor por defecto: anthropic | openai | openrouter
LEGISLACION_PROVEEDOR_DEFECTO=anthropic

# Modelos (opcionales; estos son los valores por defecto)
# LEGISLACION_MODELO_ANTHROPIC=claude-opus-4-8
# LEGISLACION_MODELO_OPENAI=gpt-5
# Lista separada por comas de modelos OpenRouter (por defecto: gpt-5.5, claude-opus-4.8,
# claude-sonnet-5, gemini-3.6-flash, grok-4.5, deepseek-v4-pro y mistral-large-2512)
# LEGISLACION_MODELOS_OPENROUTER=openai/gpt-5.5,anthropic/claude-opus-4.8

# Seguridad (recomendado en producción)
# Orígenes CORS permitidos, separados por comas (por defecto * = cualquiera).
# En producción, poner solo el dominio de la landing: https://tu-dominio.example
LEGISLACION_CORS_ORIGENES=*
# Límite de peticiones por minuto y por IP (0 = sin límite)
LEGISLACION_LIMITE_CONSULTA_POR_MINUTO=20
LEGISLACION_LIMITE_COMPARAR_POR_MINUTO=5
